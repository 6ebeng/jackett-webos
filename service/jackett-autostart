#!/bin/sh
#
# webOS Homebrew startup hook for Jackett.
#
# Copy this file to /var/lib/webosbrew/init.d/jackett (and chmod +x) so the
# Homebrew Channel "Startup Script" feature launches Jackett at boot.
# The deploy script does this for you when run with -Autostart.
#
for d in /media/developer/apps/usr/palm/services/com.jackett.app.service \
         /media/cryptofs/apps/usr/palm/services/com.jackett.app.service; do
    if [ -f "$d/jackett-run.sh" ]; then
        sh "$d/jackett-run.sh" start >/dev/null 2>&1 &
        break
    fi
done
exit 0
