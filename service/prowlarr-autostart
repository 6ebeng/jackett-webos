#!/bin/sh
#
# webOS Homebrew startup hook for Prowlarr.
#
# Copy this file to /var/lib/webosbrew/init.d/prowlarr (and chmod +x) so the
# Homebrew Channel "Startup Script" feature launches Prowlarr at boot.
# The deploy script does this for you when run with -Autostart.
#
for d in /media/developer/apps/usr/palm/services/com.prowlarr.app.service \
         /media/cryptofs/apps/usr/palm/services/com.prowlarr.app.service; do
    if [ -f "$d/prowlarr-run.sh" ]; then
        sh "$d/prowlarr-run.sh" start >/dev/null 2>&1 &
        break
    fi
done
exit 0
